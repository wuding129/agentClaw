# ============================================================
# 环境变量配置
# ============================================================
# 复制此文件为 .env 并填写实际值：
#   cp .env.example .env
#
# 本文件由 docker-compose.yml 读取，用于配置 SkillClaw 平台服务。
# ============================================================

# ── LLM 服务商 API Key ──────────────────────────────────────
# 至少配置一个 API Key，否则无法调用大模型。
# 只需填写你实际使用的服务商，其余留空即可。

# Anthropic (Claude 系列模型)
ANTHROPIC_API_KEY=

# OpenAI (GPT 系列模型)
OPENAI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# OpenRouter (聚合多家模型的代理服务)
OPENROUTER_API_KEY=

# 阿里云 DashScope (通义千问系列模型)
DASHSCOPE_API_KEY=

# AIHubMix (聚合代理服务)
AIHUBMIX_API_KEY=

# Moonshot (月之暗面 / Kimi)
MOONSHOT_API_KEY=

# Kimi (用于 web_search 工具)
KIMI_API_KEY=

# 智谱 AI (GLM 系列模型)
ZHIPU_API_KEY=

# ── Web 搜索 API Key ────────────────────────────────────────
# 用于技能中的 web_search / web_fetch 工具
# OpenClaw 按顺序自动检测: Brave → Gemini → Kimi → Perplexity → Grok

# Brave Search API (推荐，每月有免费额度)
BRAVE_API_KEY=

# Perplexity API (用于 web_search)
PERPLEXITY_API_KEY=

# ── 自部署 / 本地模型 (vLLM) ─────────────────────────────────
# 如果你用 vLLM 部署了本地模型，需要配置以下两项。
# API Key 可以填任意非空字符串（vLLM 默认不校验 key）。
#
# 启动 vLLM 示例：
#   vllm serve /data/server/models/Qwen3-14B --served-model-name Qwen3-14B --enable-auto-tool-choice --tool-call-parser hermes --port 8900
#
# 配置后将 DEFAULT_MODEL 设为你的模型名即可：
#   DEFAULT_MODEL=Qwen3-14B
HOSTED_VLLM_API_KEY=
HOSTED_VLLM_API_BASE=
# 示例：
# HOSTED_VLLM_API_KEY=dummy
# HOSTED_VLLM_API_BASE=http://localhost:8000/v1

# ── 默认模型 ─────────────────────────────────────────────────
# 新用户的默认模型，格式为 provider/model-name
# 需要与上方配置的 API Key 对应的服务商匹配
DEFAULT_MODEL=dashscope/qwen3-coder-plus

# ── Bridge 配置 ─────────────────────────────────────────────
# 是否启用技能自动审核（AI自动初审 + 人工二审）
# 设为 true 时，Bridge 会创建 skill-reviewer agent 并启动自动审核
# 设为 false（默认）时，仅使用人工审核，不创建审核 agent
BRIDGE_ENABLE_AUTO_REVIEW=false

# ── 安全配置 ─────────────────────────────────────────────────
# JWT 签名密钥，用于用户认证 token 的签发与验证
# 生产环境务必修改为随机强密钥！可用命令生成：
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-in-production
